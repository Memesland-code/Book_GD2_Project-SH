  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'Hey, you''re finally awake.

    Let me present myself. I am John, a member
    of The Anvil Community. I''m talking to you through your radio.

    You''re
    lucky we were able to detect you in these ruins.


    I don''t know what you
    remember about but you will see that our world has changed a little since the
    Great War and the Green Smoke.


    Anyway, let''s get you out of here, I will
    explain everything when you will be safe. Don''t worry, I''m going to guide you
    through this hell.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
